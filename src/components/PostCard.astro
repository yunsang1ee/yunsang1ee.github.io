---
import type { PostEntry } from "../lib/content";
import { formatDate, postHref, tagSlug, withBase } from "../lib/content";
import { categoryBySlug } from "../data/site";

interface Props {
  post: PostEntry;
  compact?: boolean;
}

const { post, compact = false } = Astro.props;
const category = categoryBySlug[post.data.category as keyof typeof categoryBySlug];
const href = withBase(postHref(post));
---

<article class:list={["content-card", "post-card", compact && "post-card--compact"]} data-card-link={href}>
  <div class="content-card__meta">
    <a href={withBase(`/categories/${post.data.category}/`)}>{category?.title ?? post.data.category}</a>
    <span>{formatDate(post.data.pubDate)}</span>
  </div>
  <h3><a href={href}>{post.data.title}</a></h3>
  {!compact && <p>{post.data.description}</p>}
  {post.data.tags.length > 0 && (
    <ul class="tag-list" aria-label={`${post.data.title} tags`}>
      {post.data.tags.map((tag) => (
        <li><a href={withBase(`/tags/${tagSlug(tag)}/`)}>{tag}</a></li>
      ))}
    </ul>
  )}
  <a class="card-open" href={href} aria-label={`Open ${post.data.title}`}>Open <span aria-hidden="true">-></span></a>
</article>
