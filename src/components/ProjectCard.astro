---
import type { ProjectEntry } from "../lib/content";
import { projectHref, withBase } from "../lib/content";

interface Props {
  project: ProjectEntry;
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
const { data } = project;
const href = withBase(projectHref(project));
---

<article class:list={["content-card", "project-card", compact && "project-card--compact"]} data-card-link={href}>
  <div class="content-card__meta">
    <span>{data.period}</span>
    <span>{data.status}</span>
  </div>
  <h3><a href={href}>{data.title}</a></h3>
  <p class="project-card__role">{data.role}</p>
  {!compact && <p>{data.description}</p>}
  <ul class="tag-list" aria-label={`${data.title} stack`}>
    {data.stack.slice(0, compact ? 4 : data.stack.length).map((item) => <li>{item}</li>)}
  </ul>
  {!compact && data.links.length > 0 && (
    <div class="link-row">
      {data.links.map((link) => (
        <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
      ))}
    </div>
  )}
  <a class="card-open" href={href} aria-label={`Open ${data.title}`}>Open <span aria-hidden="true">-></span></a>
</article>
