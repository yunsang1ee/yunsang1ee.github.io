---
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags, getPublishedPosts, tagSlug, withBase } from "../../lib/content";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = getAllTags(posts);

  return tags.map((tag) => ({
    params: { tag: tagSlug(tag) },
    props: {
      tag,
      posts: posts.filter((post) => post.data.tags.includes(tag))
    }
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`Tag: ${tag}`} description={`${tag} 태그 글 목록`}>
  <section class="shell page-head">
    <p class="eyebrow">Tag</p>
    <h1>{tag}</h1>
    <p>{tag}와 연결된 글을 모았습니다.</p>
    <nav class="index-switch" aria-label="Topic index">
      <a href={withBase("/categories/")}>Categories</a>
      <a href={withBase("/tags/")} aria-current="page">Tags</a>
    </nav>
  </section>

  <section class="shell listing-shell">
    <aside class="left-rail">
      <div class="rail-panel">
        <p class="rail-kicker">Tag</p>
        <h2>{posts.length} notes</h2>
      </div>
    </aside>

    <div class="content-grid">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
