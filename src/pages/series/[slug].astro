---
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts, getSeriesGroups } from "../../lib/content";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const seriesGroups = getSeriesGroups(posts);

  return seriesGroups.map((series) => ({
    params: { slug: series.slug },
    props: { series }
  }));
}

const { series } = Astro.props;
---

<BaseLayout title={series.title} description={`${series.title} series`}>
  <section class="shell page-head">
    <p class="eyebrow">Series</p>
    <h1>{series.title}</h1>
    <p>순서가 있는 글 묶음입니다. 긴 구현기나 학습 기록은 이 단위로 정리합니다.</p>
  </section>

  <section class="shell listing-shell">
    <aside class="left-rail">
      <div class="rail-panel">
        <p class="rail-kicker">Track</p>
        <h2>{series.posts.length} notes</h2>
      </div>
    </aside>

    <div class="content-grid">
      {series.posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
