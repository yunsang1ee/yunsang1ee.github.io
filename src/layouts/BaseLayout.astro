---
import { navItems, site } from "../data/site";
import { withBase } from "../lib/content";

interface Props {
  title?: string;
  description?: string;
}

const { title = site.title, description = site.description } = Astro.props;
const pageTitle = title === site.title ? site.title : `${title} | ${site.title}`;
const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  const normalized = withBase(href);
  if (href === "/categories/" && pathname.startsWith(withBase("/tags/"))) return true;
  return pathname === normalized || (href !== "/" && pathname.startsWith(normalized));
};
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={withBase("/favicon.svg")} />
    <script is:inline>
      (() => {
        try {
          const storedTheme = localStorage.getItem("theme");
          document.documentElement.dataset.theme = storedTheme === "dark" ? "dark" : "light";
        } catch {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f3f3f1;
        --bg-strong: #ecece8;
        --surface: #ffffff;
        --surface-soft: #f9f9f6;
        --text: #18181b;
        --muted: #6c6c66;
        --faint: #8d8d86;
        --line: #e4e4de;
        --line-strong: #cfcfc6;
        --accent: #3e8e73;
        --accent-dark: #23624d;
        --rust: #b75f3b;
        --blue: #496e9f;
        --violet: #6d5ca7;
        --slate: #545b62;
        --grid-line: rgba(24, 24, 27, 0.035);
        --header-bg: rgba(243, 243, 241, 0.9);
        --panel-bg: rgba(255, 255, 255, 0.72);
        --showcase-shadow: 0 18px 52px rgba(24, 24, 27, 0.08);
        --tag-hover: #dfe6e1;
        --code-bg: #18181b;
        --code-text: #f9f9f6;
        --radius: 8px;
        --shell: 1180px;
        --mono: "JetBrains Mono", "SFMono-Regular", Consolas, "Liberation Mono", monospace;
        --sans: Pretendard, "IBM Plex Sans KR", "Noto Sans KR", ui-sans-serif, system-ui, -apple-system,
          BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      :root[data-theme="dark"] {
        color-scheme: dark;
        --bg: #11100e;
        --bg-strong: #1d1b17;
        --surface: #181713;
        --surface-soft: #211f1a;
        --text: #f2eee7;
        --muted: #b8b1a5;
        --faint: #928a7d;
        --line: #343129;
        --line-strong: #524d40;
        --accent: #74bd99;
        --accent-dark: #9bd8bc;
        --rust: #d68a61;
        --blue: #84aadd;
        --violet: #aa9de3;
        --slate: #a5aaa9;
        --grid-line: rgba(242, 238, 231, 0.035);
        --header-bg: rgba(17, 16, 14, 0.88);
        --panel-bg: rgba(24, 23, 19, 0.78);
        --showcase-shadow: 0 18px 60px rgba(0, 0, 0, 0.28);
        --tag-hover: #26362f;
        --code-bg: #0d0d0c;
        --code-text: #f4efe7;
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
      }

      body {
        min-width: 320px;
        margin: 0;
        background:
          linear-gradient(var(--grid-line) 1px, transparent 1px),
          var(--bg);
        background-size: 100% 28px;
        color: var(--text);
        font-family: var(--sans);
        letter-spacing: 0;
        line-break: strict;
        overflow-wrap: break-word;
        word-break: keep-all;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img,
      canvas {
        max-width: 100%;
      }

      p {
        margin: 0;
        color: var(--muted);
        line-height: 1.75;
        overflow-wrap: break-word;
        word-break: keep-all;
      }

      h1,
      h2,
      h3,
      h4 {
        margin: 0;
        color: var(--text);
        line-height: 1.18;
        letter-spacing: 0;
        overflow-wrap: break-word;
        text-wrap: balance;
        word-break: keep-all;
      }

      h1 {
        font-size: 4rem;
      }

      h2 {
        font-size: 2rem;
      }

      h3 {
        font-size: 1.05rem;
      }

      code,
      pre,
      .mono {
        font-family: var(--mono);
        overflow-wrap: anywhere;
        word-break: normal;
      }

      main {
        min-height: 72vh;
      }

      .shell {
        width: min(100% - 40px, var(--shell));
        margin-inline: auto;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 30;
        border-bottom: 1px solid var(--line);
        background: var(--header-bg);
        backdrop-filter: blur(16px);
      }

      .site-header__inner {
        display: flex;
        min-height: 64px;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .brand {
        display: grid;
        gap: 2px;
        min-width: max-content;
      }

      .brand strong {
        font-size: 1rem;
      }

      .brand span {
        color: var(--muted);
        font-family: var(--mono);
        font-size: 0.76rem;
      }

      .primary-nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 4px;
      }

      .header-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
      }

      .primary-nav a {
        border-radius: 999px;
        color: var(--muted);
        font-size: 0.88rem;
        padding: 8px 11px;
      }

      .primary-nav a:hover,
      .primary-nav a[aria-current="page"] {
        background: var(--bg-strong);
        color: var(--text);
      }

      .theme-toggle {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 34px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--surface);
        color: var(--muted);
        cursor: pointer;
        font: 700 0.78rem var(--sans);
        padding: 4px 9px 4px 5px;
      }

      .theme-toggle:hover {
        border-color: var(--line-strong);
        color: var(--text);
      }

      .theme-toggle__track {
        position: relative;
        display: inline-flex;
        width: 42px;
        height: 24px;
        border-radius: 999px;
        background: var(--bg-strong);
        box-shadow: inset 0 0 0 1px var(--line);
      }

      .theme-toggle__thumb {
        position: absolute;
        top: 4px;
        left: 4px;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: var(--text);
        transition: transform 160ms ease;
      }

      :root[data-theme="dark"] .theme-toggle__thumb {
        transform: translateX(18px);
      }

      .site-footer {
        margin-top: 72px;
        border-top: 1px solid var(--line);
        background: var(--surface);
        color: var(--muted);
        padding: 28px 0;
      }

      .site-footer p {
        font-size: 0.92rem;
      }

      .text-link,
      .content-card h3 a,
      .prose a {
        color: var(--accent-dark);
      }

      .text-link:hover,
      .content-card h3 a:hover,
      .prose a:hover {
        color: var(--accent);
      }

      .eyebrow,
      .content-card__meta,
      .rail-kicker,
      .crumbs,
      .project-card__role {
        color: var(--faint);
        font-family: var(--mono);
        font-size: 0.78rem;
      }

      .eyebrow {
        margin-bottom: 10px;
      }

      .link-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .page-head {
        padding: 58px 0 28px;
      }

      .page-head p {
        max-width: 760px;
        margin-top: 14px;
      }

      .home-hero {
        display: grid;
        grid-template-columns: minmax(0, 0.92fr) minmax(380px, 0.72fr);
        gap: 42px;
        align-items: center;
        padding: 56px 0 36px;
      }

      .home-hero__copy {
        display: grid;
        gap: 18px;
      }

      .home-hero__copy p {
        max-width: 680px;
      }

      .home-hero__copy h1 {
        max-width: 10ch;
      }

      .hero-links {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
      }

      .hero-links a {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border-bottom: 1px solid var(--line-strong);
        color: var(--accent-dark);
        font-size: 0.94rem;
        font-weight: 700;
        padding-bottom: 3px;
      }

      .hero-links a:hover {
        color: var(--accent);
        border-bottom-color: var(--accent);
      }

      .index-switch {
        display: inline-grid;
        grid-template-columns: repeat(2, 118px);
        gap: 4px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--surface);
        padding: 4px;
      }

      .index-switch a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 34px;
        border-radius: 999px;
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 700;
        padding: 0 12px;
      }

      .index-switch a:hover {
        background: var(--bg-strong);
        color: var(--text);
      }

      .index-switch a[aria-current="page"] {
        background: var(--text);
        color: var(--surface);
      }

      .hero-showcase {
        display: block;
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--surface);
        box-shadow: var(--showcase-shadow);
      }

      .hero-showcase:hover {
        border-color: var(--line-strong);
      }

      .hero-showcase__media {
        overflow: hidden;
        aspect-ratio: 21 / 10;
        background: var(--bg-strong);
      }

      .hero-showcase img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 62%;
      }

      .hero-showcase__caption {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        border-top: 1px solid var(--line);
        padding: 14px 16px;
      }

      .hero-showcase__caption h2 {
        font-size: 1.05rem;
        margin-top: 3px;
      }

      .hero-showcase__caption span {
        color: var(--faint);
        font-family: var(--mono);
        font-size: 0.72rem;
      }

      .knowledge-shell,
      .listing-shell,
      .post-shell,
      .project-shell {
        display: grid;
        gap: 22px;
        align-items: start;
      }

      .knowledge-shell {
        grid-template-columns: 230px minmax(0, 1fr) 280px;
        padding: 22px 0 20px;
      }

      .home-knowledge {
        grid-template-columns: 230px minmax(0, 1fr);
      }

      .home-dashboard {
        padding: 22px 0 20px;
      }

      .home-state {
        display: grid;
        grid-template-columns: 230px minmax(0, 1fr);
        gap: 28px;
        align-items: start;
      }

      .listing-shell,
      .project-shell {
        grid-template-columns: 250px minmax(0, 1fr);
      }

      .post-shell {
        grid-template-columns: 210px minmax(0, 760px) 230px;
        justify-content: center;
      }

      .left-rail,
      .right-rail,
      .toc-rail {
        position: sticky;
        top: 84px;
        display: grid;
        gap: 14px;
      }

      .rail-panel {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--panel-bg);
        padding: 16px;
      }

      .rail-panel h2,
      .rail-panel h3 {
        font-size: 0.98rem;
      }

      .rail-list {
        display: grid;
        gap: 7px;
        margin: 12px 0 0;
        padding: 0;
        list-style: none;
      }

      .rail-list a,
      .rail-list > li > span {
        display: flex;
        min-width: 0;
        min-height: 32px;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        border-radius: 6px;
        color: var(--muted);
        font-size: 0.9rem;
        padding: 6px 8px;
        overflow-wrap: break-word;
        word-break: keep-all;
      }

      .rail-list a {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
      }

      .rail-list a > span {
        min-width: 0;
      }

      .rail-list strong {
        justify-self: end;
        white-space: nowrap;
      }

      [data-rail="projects"] .rail-list a {
        grid-template-columns: 1fr;
        justify-items: start;
        gap: 3px;
      }

      [data-rail="projects"] .rail-list strong {
        justify-self: start;
        border-radius: 999px;
        background: var(--bg-strong);
        color: var(--muted);
        font-size: 0.75rem;
        line-height: 1;
        padding: 4px 8px;
      }

      .rail-list a:hover {
        background: var(--bg-strong);
        color: var(--text);
      }

      .section-block {
        display: grid;
        gap: 14px;
        margin-bottom: 28px;
      }

      .home-state > input {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(0 0 0 0);
        clip-path: inset(50%);
        white-space: nowrap;
      }

      .home-rail-panel {
        display: none;
        gap: 14px;
        min-width: 0;
      }

      #home-tab-notes:checked ~ .home-rail [data-rail="notes"],
      #home-tab-projects:checked ~ .home-rail [data-rail="projects"],
      #home-tab-topics:checked ~ .home-rail [data-rail="topics"] {
        display: grid;
      }

      .home-tabs {
        min-width: 0;
      }

      .home-tab-list {
        display: inline-grid;
        grid-template-columns: repeat(3, 78px);
        gap: 4px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--surface);
        padding: 4px;
      }

      .home-tab-list label {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 0;
        min-height: 34px;
        border-radius: 999px;
        color: var(--muted);
        cursor: pointer;
        font-size: 0.9rem;
        font-weight: 700;
        padding: 0 14px;
        user-select: none;
      }

      .home-tab-list label:hover {
        background: var(--bg-strong);
        color: var(--text);
      }

      #home-tab-notes:focus-visible ~ .home-tabs .home-tab-list label[for="home-tab-notes"],
      #home-tab-projects:focus-visible ~ .home-tabs .home-tab-list label[for="home-tab-projects"],
      #home-tab-topics:focus-visible ~ .home-tabs .home-tab-list label[for="home-tab-topics"] {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      #home-tab-notes:checked ~ .home-tabs .home-tab-list label[for="home-tab-notes"],
      #home-tab-projects:checked ~ .home-tabs .home-tab-list label[for="home-tab-projects"],
      #home-tab-topics:checked ~ .home-tabs .home-tab-list label[for="home-tab-topics"] {
        background: var(--text);
        color: var(--surface);
      }

      .home-tab-panels {
        margin-top: 18px;
      }

      .home-tab-panel {
        display: none;
      }

      #home-tab-notes:checked ~ .home-tabs .home-tab-panels [data-panel="notes"],
      #home-tab-projects:checked ~ .home-tabs .home-tab-panels [data-panel="projects"],
      #home-tab-topics:checked ~ .home-tabs .home-tab-panels [data-panel="topics"] {
        display: block;
      }

      .section-block__head {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 18px;
      }

      .content-grid,
      .project-grid {
        display: grid;
        gap: 14px;
      }

      .project-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .content-card {
        position: relative;
        min-width: 0;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--surface);
        padding: 18px;
        transition:
          border-color 140ms ease,
          background-color 140ms ease,
          box-shadow 140ms ease,
          transform 140ms ease;
      }

      .content-card:hover {
        border-color: var(--line-strong);
        background: var(--surface-soft);
      }

      .content-card[data-card-link] {
        cursor: pointer;
      }

      .content-card[data-card-link]:hover {
        box-shadow: 0 10px 28px rgba(24, 24, 27, 0.08);
        transform: translateY(-1px);
      }

      :root[data-theme="dark"] .content-card[data-card-link]:hover {
        box-shadow: 0 10px 32px rgba(0, 0, 0, 0.24);
      }

      .content-card__meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 12px;
      }

      .content-card h3 {
        margin-bottom: 9px;
      }

      .post-card--compact,
      .project-card--compact {
        padding: 14px;
      }

      .card-open {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        color: var(--accent-dark);
        font-family: var(--mono);
        font-size: 0.76rem;
        font-weight: 700;
        margin-top: 14px;
      }

      .content-card:hover .card-open {
        color: var(--accent);
      }

      .tag-list {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        margin: 14px 0 0;
        min-width: 0;
        padding: 0;
        list-style: none;
      }

      .tag-list li,
      .tag-list a,
      .pill {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        background: var(--bg-strong);
        color: var(--muted);
        font-size: 0.78rem;
        min-height: 26px;
        max-width: 100%;
        padding: 4px 9px;
      }

      .tag-list a:hover,
      .pill:hover {
        background: var(--tag-hover);
        color: var(--accent-dark);
      }

      .link-row {
        margin-top: 14px;
      }

      .link-row a {
        color: var(--accent-dark);
        font-size: 0.9rem;
        font-weight: 700;
      }

      .category-map {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
      }

      .category-card {
        position: relative;
        overflow: hidden;
        min-height: 170px;
      }

      .category-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto;
        height: 3px;
        background: var(--accent);
      }

      .category-card[data-accent="blue"]::before {
        background: var(--blue);
      }

      .category-card[data-accent="rust"]::before {
        background: var(--rust);
      }

      .category-card[data-accent="slate"]::before {
        background: var(--slate);
      }

      .category-card[data-accent="violet"]::before {
        background: var(--violet);
      }

      .category-card[data-accent="gray"]::before {
        background: var(--faint);
      }

      .topic-index-card {
        display: grid;
        gap: 12px;
      }

      .topic-index-card__head {
        display: flex;
        align-items: start;
        justify-content: space-between;
        gap: 16px;
      }

      .topic-index-card__count {
        flex: 0 0 auto;
        border-radius: 999px;
        background: var(--bg-strong);
        color: var(--muted);
        font-family: var(--mono);
        font-size: 0.75rem;
        font-weight: 700;
        padding: 5px 9px;
        white-space: nowrap;
      }

      .tag-index-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
      }

      .tag-index-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        min-height: 52px;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--surface);
        padding: 13px 14px;
      }

      .tag-index-item:hover {
        border-color: var(--line-strong);
        background: var(--surface-soft);
      }

      .tag-index-item strong {
        flex: 0 0 auto;
        border-radius: 999px;
        background: var(--bg-strong);
        color: var(--muted);
        font-family: var(--mono);
        font-size: 0.75rem;
        padding: 4px 8px;
      }

      .prose-card {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--surface);
        padding: 34px;
      }

      .prose-header {
        border-bottom: 1px solid var(--line);
        margin-bottom: 30px;
        padding-bottom: 24px;
      }

      .prose-header h1 {
        font-size: 2.6rem;
        max-width: 820px;
      }

      .prose-header p {
        margin-top: 14px;
      }

      .prose {
        font-size: 1rem;
      }

      .prose h2 {
        border-top: 1px solid var(--line);
        font-size: 1.55rem;
        margin-top: 42px;
        padding-top: 28px;
      }

      .prose h3 {
        font-size: 1.18rem;
        margin-top: 30px;
      }

      .prose p,
      .prose ul,
      .prose ol,
      .prose blockquote {
        color: var(--muted);
        line-height: 1.82;
        word-break: keep-all;
      }

      .prose p,
      .prose ul,
      .prose ol,
      .prose blockquote,
      .prose pre {
        margin: 16px 0 0;
      }

      .prose blockquote {
        border-left: 3px solid var(--accent);
        background: var(--surface-soft);
        margin-left: 0;
        padding: 14px 18px;
      }

      .prose code {
        border-radius: 4px;
        background: var(--bg-strong);
        color: var(--text);
        font-size: 0.9em;
        padding: 2px 5px;
      }

      .prose pre {
        overflow: auto;
        border-radius: var(--radius);
        background: var(--code-bg);
        color: var(--code-text);
        padding: 16px;
      }

      .prose pre code {
        background: transparent;
        color: inherit;
        padding: 0;
      }

      .toc-list {
        display: grid;
        gap: 8px;
        margin: 12px 0 0;
        padding: 0;
        list-style: none;
      }

      .toc-list a {
        color: var(--muted);
        font-size: 0.86rem;
      }

      .toc-list a:hover {
        color: var(--accent-dark);
      }

      @media (max-width: 1080px) {
        .knowledge-shell,
        .post-shell {
          grid-template-columns: minmax(0, 1fr) 270px;
        }

        .left-rail,
        .toc-rail {
          position: static;
          grid-column: 1 / -1;
        }

        .home-state > .home-rail {
          grid-column: auto;
        }

        .listing-shell,
        .project-shell {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 760px) {
        h1 {
          font-size: 2.55rem;
        }

        h2 {
          font-size: 1.55rem;
        }

        .shell {
          width: min(100% - 28px, var(--shell));
        }

        .site-header__inner {
          align-items: flex-start;
          flex-direction: column;
          gap: 10px;
          padding: 13px 0;
        }

        .header-actions {
          align-items: flex-start;
          flex-direction: column;
          gap: 8px;
          width: 100%;
        }

        .primary-nav {
          justify-content: flex-start;
        }

        .home-hero,
        .home-state,
        .knowledge-shell,
        .post-shell {
          grid-template-columns: 1fr;
        }

        .home-tabs {
          order: 1;
        }

        .home-rail {
          order: 2;
        }

        .hero-showcase__caption {
          align-items: flex-start;
          flex-direction: column;
        }

        .home-hero {
          padding-top: 36px;
        }

        .right-rail {
          position: static;
        }

        .project-grid,
        .category-map,
        .tag-index-grid {
          grid-template-columns: 1fr;
        }

        .prose-card {
          padding: 22px;
        }

        .prose-header h1 {
          font-size: 2rem;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="shell site-header__inner">
        <a class="brand" href={withBase("/")}>
          <strong>{site.title}</strong>
          <span>{site.authorEn} / {site.authorKo}</span>
        </a>
        <div class="header-actions">
          <nav class="primary-nav" aria-label="Primary navigation">
            {navItems.map((item) => (
              <a href={withBase(item.href)} aria-current={isActive(item.href) ? "page" : undefined}>
                {item.label}
              </a>
            ))}
          </nav>
          <button class="theme-toggle" type="button" aria-label="Toggle dark mode" aria-pressed="false" data-theme-toggle>
            <span class="theme-toggle__track" aria-hidden="true">
              <span class="theme-toggle__thumb"></span>
            </span>
            <span data-theme-label>Dark</span>
          </button>
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell">
        <p>
          {site.title} by {site.authorEn}. <a class="text-link" href={site.github} target="_blank" rel="noreferrer">GitHub</a>
          {" / "}
          <a class="text-link" href={`mailto:${site.email}`}>{site.email}</a>
        </p>
      </div>
    </footer>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const toggle = document.querySelector("[data-theme-toggle]");
        const label = document.querySelector("[data-theme-label]");
        if (!toggle || !label) return;

        const applyTheme = (theme) => {
          const normalized = theme === "dark" ? "dark" : "light";
          root.dataset.theme = normalized;
          toggle.setAttribute("aria-pressed", normalized === "dark" ? "true" : "false");
          label.textContent = normalized === "dark" ? "Light" : "Dark";
          try {
            localStorage.setItem("theme", normalized);
          } catch {}
        };

        applyTheme(root.dataset.theme);
        toggle.addEventListener("click", () => {
          applyTheme(root.dataset.theme === "dark" ? "light" : "dark");
        });

        document.querySelectorAll("[data-card-link]").forEach((card) => {
          card.addEventListener("click", (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;
            if (target.closest("a, button, input, label")) return;

            const href = card.getAttribute("data-card-link");
            if (href) window.location.href = href;
          });
        });
      })();
    </script>
  </body>
</html>
